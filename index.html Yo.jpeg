<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Juanjo | Desarrollador Frontend</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: linear-gradient(135deg, #0f172a, #1e293b, #020617);
  color: white;
  text-align: center;
}

/* HEADER */
header {
  padding: 80px 20px 60px;
}

/* TITULOS */
h1 {
  font-size: 52px;
  margin-bottom: 20px;
  animation: aparecerTexto 1.5s ease;
}

h2 {
  font-size: 34px;
  margin-bottom: 25px;
}

h3 {
  font-size: 22px;
}

@keyframes aparecerTexto {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* TEXTOS */
p {
  margin: 15px auto;
  color: #cbd5f5;
  line-height: 1.6;
  max-width: 600px;
  font-size: 18px;
}

/* SECCIONES */
section {
  padding: 60px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ANIMACIÓN SCROLL */
.animado {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.8s ease;
}

.mostrar {
  opacity: 1;
  transform: translateY(0);
}

/* CONTENEDOR */
.contenedor {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 25px;
  margin-top: 30px;
}

/* TARJETAS */
.card {
  background: rgba(30, 41, 59, 0.8);
  backdrop-filter: blur(10px);
  padding: 25px;
  border-radius: 15px;
  width: 280px;
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-8px) scale(1.03);
}

/* BOTON */
.btn {
  display: inline-block;
  margin-top: 20px;
  padding: 12px 25px;
  background: #38bdf8;
  color: black;
  border-radius: 8px;
  text-decoration: none;
  font-weight: bold;
  transition: 0.3s;
}

.btn:hover {
  background: #0ea5e9;
}

/* FOTO */
.foto {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  object-fit: cover;
  margin-top: 20px;
  border: 4px solid #38bdf8;

  opacity: 0;
  transform: translateY(-20px);
  animation: aparecerFoto 1.5s ease forwards;
}

@keyframes aparecerFoto {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* FOOTER */
footer {
  padding: 25px;
  background: #020617;
  margin-top: 40px;
}
</style>
</head>

<body>

<header>
  <h1>Hola, soy Mbappé 🚀</h1>
  <p>Desarrollador frontend enfocado en crear páginas web modernas y funcionales</p>
  <img src="Yo.jpeg" alt="Mi foto" class="foto">
</header>

<section class="animado">
  <h2>Sobre mí</h2>
  <p>Estoy construyendo proyectos reales para trabajar como freelancer. Me enfoco en crear sitios web rápidos, limpios y funcionales.</p>
</section>

<section class="animado">
  <h2>PROYECTOS</h2>

  <div class="contenedor">
    <div class="card">
      <h3>Página personal</h3>
      <p>Mi primera web desarrollada con HTML y CSS.</p>
    </div>

    <div class="card">
      <h3>Proyecto en progreso</h3>
      <p>Próximamente más proyectos con mejor diseño y funcionalidades.</p>
    </div>
  </div>
</section>

<section class="animado">
  <h2>Contacto</h2>
  <p>Disponible para trabajos freelance</p>

  <a class="btn" href="https://wa.me/573188522236" target="_blank">
    Escríbeme por WhatsApp
  </a>
</section>

<footer>
  <p>© 2026 Mbappé</p>
</footer>

<script>
const elementos = document.querySelectorAll('.animado');

function mostrarElementos() {
  elementos.forEach(el => {
    const top = el.getBoundingClientRect().top;
    if (top < window.innerHeight - 100) {
      el.classList.add('mostrar');
    }
  });
}

window.addEventListener('scroll', mostrarElementos);
window.addEventListener('load', mostrarElementos);
</script>

</body>
</html>
